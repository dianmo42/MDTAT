
dump            1 all custom 500 TAT.dump type xs ys zs
dump_modify     1 sort id

# Run simulation
fix             1 all npt temp ${Tstart} ${Tstop} $(v_Tdamp*dt) iso ${Pstart} ${Pstop} $(v_Pdamp*dt)
fix             1 all npt temp 300 ${Tstop} $(v_Tdamp*dt) iso ${Pstart} ${Pstop} $(v_Pdamp*dt)
fix             1 all npt temp 300 300 $(v_Tdamp*dt) iso ${Pstart} ${Pstop} $(v_Pdamp*dt)
fix             1 all npt temp 300 300 0.2000000000000000111 iso ${Pstart} ${Pstop} $(v_Pdamp*dt)
fix             1 all npt temp 300 300 0.2000000000000000111 iso 0 ${Pstop} $(v_Pdamp*dt)
fix             1 all npt temp 300 300 0.2000000000000000111 iso 0 0 $(v_Pdamp*dt)
fix             1 all npt temp 300 300 0.2000000000000000111 iso 0 0 2
run             $(v_t_sim/dt)
run             5000
